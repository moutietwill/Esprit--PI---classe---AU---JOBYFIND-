# Configuration Email - Copier ce fichier en .env et remplir vos paramètres

# Pilote d'envoi d'email: 'sendmail' (local) ou 'smtp' (serveur)
MAIL_DRIVER=sendmail

# Configuration SMTP (si MAIL_DRIVER=smtp)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-applicatif
MAIL_ENCRYPTION=tls

# Email par défaut
MAIL_FROM_NAME=Gestion Événements
MAIL_FROM_EMAIL=noreply@evenements.local

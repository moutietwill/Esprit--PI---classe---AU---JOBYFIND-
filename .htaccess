<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # If we are in a subdirectory, we need to handle it.
    # But usually RewriteBase / works if we redirect to a relative path.
    
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>
